<div class="main-app">
  <nav class="app-nav">
    <div style="display: flex; align-items: center;">
      <a href="/home" class="logo">
        <img src="https://res.cloudinary.com/basejump/image/upload/v1580630789/basecamp-logo-mini.png" alt="Home" />
      </a>
      <a href="<%= project_path(@project) %>" class="logo" style="margin-left: 5px;">
        <span><%= @project.name %></span>
      </a>
    </div>
    <div>
      <a href="<%= user_path(current_user) %>" style="font-size: 13px; color: #555; text-decoration: none;"><%= current_user.name %></a>
      <%= button_to "Logout", session_path, method: :delete, class: "btn btn-normal", style: "padding: 5px 10px; font-size: 12px;" %>
    </div>
  </nav>

  <div class="tool-page">
    <header>
      <span><%= link_to "← #{@project.name}", project_path(@project) %></span>
    </header>

    <div class="main-tool">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h1 style="margin: 0;">Docs</h1>
        <%= link_to "New Page", new_project_doc_path(@project), class: "btn btn-submit" %>
      </div>

      <div id="notes">
        <% if @notes.any? %>
          <div class="todolists">
            <% @notes.each do |note| %>
              <div class="todo" style="margin-bottom: 12px;">
                <div style="flex: 1;">
                  <span style="font-size: 17px;">
                    <%= link_to note.title, doc_path(note), style: "color: #333; text-decoration: none;" %>
                  </span>
                  <% if note.author %>
                    <p style="font-size: 11px; color: #999; margin: 2px 0;">
                      by <%= note.author.name %> · <%= note.created_at.strftime("%b %d, %Y") %>
                    </p>
                  <% end %>
                  <% if note.children.any? %>
                    <p style="font-size: 12px; color: #666; margin: 4px 0;">
                      <%= note.children.count %> sub-pages
                    </p>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div style="text-align: center; padding: 40px; color: #999;">
            <p>No pages yet. Create your first page!</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
