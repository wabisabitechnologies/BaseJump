<%= turbo_stream.prepend "notes" do %>
  <div class="todo" style="margin-bottom: 12px;">
    <div style="flex: 1;">
      <span style="font-size: 17px;">
        <%= link_to @note.title, doc_path(@note), style: "color: #333; text-decoration: none;" %>
      </span>
      <p style="font-size: 11px; color: #999; margin: 2px 0;">
        by <%= @note.author.name %> · <%= @note.created_at.strftime("%b %d, %Y") %>
      </p>
    </div>
  </div>
<% end %>
