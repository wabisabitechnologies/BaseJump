<div class="main-app">
  <nav class="app-nav">
    <div style="display: flex; align-items: center;">
      <a href="/home" class="logo">
        <img src="https://res.cloudinary.com/basejump/image/upload/v1580630789/basecamp-logo-mini.png" alt="Home" />
      </a>
      <a href="<%= project_path(@project) %>" class="logo" style="margin-left: 5px;">
        <span><%= @project.name %></span>
      </a>
    </div>
    <div>
      <span style="font-size: 13px; color: #555;"><%= current_user.name %></span>
      <%= button_to "Logout", session_path, method: :delete, class: "btn btn-normal", style: "padding: 5px 10px; font-size: 12px;" %>
    </div>
  </nav>

  <div class="tool-page">
    <header>
      <span><%= link_to "← #{@project.name}", project_path(@project) %></span>
    </header>

    <div class="main-tool">
      <h1>Events & Calendar</h1>

      <div class="tool-form">
        <%= form_with url: project_events_path(@project), data: { turbo_stream: true } do |f| %>
          <div class="input-fields">
            <%= f.text_field :title, placeholder: "Event title..." %>
          </div>
          <div class="input-fields">
            <%= f.text_area :description, placeholder: "Description...", rows: 2, style: "width: 100%; font-family: inherit;" %>
          </div>
          <div class="input-fields" style="display: flex; gap: 12px;">
            <div>
              <label style="font-size: 12px; color: #666;">Start Date</label>
              <%= f.date_field :start_date, style: "padding: 4px; font-size: 14px;" %>
            </div>
            <div>
              <label style="font-size: 12px; color: #666;">End Date</label>
              <%= f.date_field :end_date, style: "padding: 4px; font-size: 14px;" %>
            </div>
          </div>
          <div class="input-fields">
            <%= f.text_field :video_link, placeholder: "Video link (optional)..." %>
          </div>
          <div class="submit-buttons">
            <%= f.submit "Create Event", class: "btn btn-submit" %>
          </div>
        <% end %>
      </div>

      <div class="todolists">
        <div id="events">
          <% @events.each do |event| %>
            <%= render partial: "events/event", locals: { event: event } %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
