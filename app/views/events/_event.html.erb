<div id="<%= dom_id(event) %>" class="todo" style="margin-bottom: 16px;">
  <div style="flex: 1;">
    <div style="display: flex; justify-content: space-between; align-items: center;">
      <h3 style="margin: 0; font-size: 17px;">
        <%= link_to event.title, project_event_path(event.project, event), style: "color: #333; text-decoration: none;" %>
      </h3>
      <span style="font-size: 12px; color: #999;">
        <%= Date.parse(event.start_date.to_s).strftime("%b %d, %Y") rescue event.start_date %>
      </span>
    </div>
    <% if event.author %>
      <p style="font-size: 12px; color: #666; margin: 4px 0;">
        by <%= event.author.name %>
      </p>
    <% end %>
    <% if event.description.present? %>
      <p style="font-size: 14px; color: #555; margin-top: 8px;">
        <%= truncate(event.description, length: 150) %>
      </p>
    <% end %>
    <% if event.video_link.present? %>
      <p style="margin-top: 8px;">
        <%= link_to "📹 Video Link", event.video_link, target: "_blank", style: "font-size: 12px; color: #007BB6;" %>
      </p>
    <% end %>
  </div>
</div>
