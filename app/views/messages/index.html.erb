<div class="main-app">
  <nav class="app-nav">
    <div style="display: flex; align-items: center;">
      <a href="/home" class="logo">
        <img src="https://res.cloudinary.com/basejump/image/upload/v1580630789/basecamp-logo-mini.png" alt="Home" />
      </a>
      <a href="<%= project_path(@project) %>" class="logo" style="margin-left: 5px;">
        <span><%= @project.name %></span>
      </a>
    </div>
    <div>
      <span style="font-size: 13px; color: #555;"><%= current_user.name %></span>
      <%= button_to "Logout", session_path, method: :delete, class: "btn btn-normal", style: "padding: 5px 10px; font-size: 12px;" %>
    </div>
  </nav>

  <div class="tool-page">
    <header>
      <span><%= link_to "← #{@project.name}", project_path(@project) %></span>
    </header>

    <div class="main-tool">
      <h1>Message Board</h1>

      <div class="tool-form">
        <%= form_with url: project_messages_path(@project), data: { turbo_stream: true } do |f| %>
          <div class="input-fields">
            <%= f.text_field :title, placeholder: "Message title..." %>
          </div>
          <div class="input-fields">
            <%= f.text_area :body, placeholder: "Write your message...", rows: 4, style: "width: 100%; font-family: inherit;" %>
          </div>
          <div class="submit-buttons">
            <%= f.submit "Post Message", class: "btn btn-submit" %>
          </div>
        <% end %>
      </div>

      <div class="todolists">
        <div id="messages">
          <% @messages.each do |message| %>
            <%= render partial: "messages/message", locals: { message: message } %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
