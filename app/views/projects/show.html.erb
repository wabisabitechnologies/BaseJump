<div class="main-app">
  <nav class="app-nav">
    <div style="display: flex; align-items: center;">
      <a href="/home" class="logo">
        <img src="https://res.cloudinary.com/basejump/image/upload/v1580630789/basecamp-logo-mini.png" alt="Home" />
      </a>
      <a href="/home" class="logo" style="margin-left: 5px;">
        <span>Home</span>
      </a>
    </div>
    <div>
      <span style="font-size: 13px; color: #555;"><%= current_user.name %></span>
      <%= button_to "Logout", session_path, method: :delete, class: "btn btn-normal", style: "padding: 5px 10px; font-size: 12px;" %>
    </div>
  </nav>

  <div class="project-page">
    <h1><%= @project.name %></h1>
    <% if @project.description.present? %>
      <h2><%= @project.description %></h2>
    <% end %>

    <ul class="tools">
      <a href="<%= project_todo_lists_path(@project) %>">
        <li class="tool-card">
          <h2>Todo Lists</h2>
          <li><%= @todo_lists.count %> lists</li>
        </li>
      </a>
      <a href="<%= project_messages_path(@project) %>">
        <li class="tool-card">
          <h2>Messages</h2>
          <li><%= @project.messages.count %> messages</li>
        </li>
      </a>
      <a href="<%= project_events_path(@project) %>">
        <li class="tool-card">
          <h2>Events</h2>
          <li><%= @project.events.count %> events</li>
        </li>
      </a>
      <a href="<%= project_docs_path(@project) %>">
        <li class="tool-card">
          <h2>Docs</h2>
          <li><%= @project.notes.count %> pages</li>
        </li>
      </a>
    </ul>

    <div style="margin-top: 20px;">
      <%= button_to "Save as Template", create_template_path(@project), 
          method: :post, 
          class: "btn btn-normal", 
          style: "font-size: 12px; margin-right: 10px;" %>
      <%= link_to "View Templates", templates_path, style: "font-size: 12px; color: #007BB6;" %>
    </div>
  </div>
</div>
