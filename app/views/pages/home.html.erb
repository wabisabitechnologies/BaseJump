<div class="main-app">
  <nav class="app-nav">
    <div style="display: flex; align-items: center;">
      <a href="/home" class="logo">
        <img src="https://res.cloudinary.com/basejump/image/upload/v1580630789/basecamp-logo-mini.png" alt="Home" />
      </a>
      <a href="/home" class="logo" style="margin-left: 5px;">
        <span>Home</span>
      </a>
    </div>
    <div>
      <a href="<%= user_path(current_user) %>" style="font-size: 13px; color: #555; text-decoration: none;"><%= current_user.name %></a>
      <%= button_to "Logout", session_path, method: :delete, class: "btn btn-normal", style: "padding: 5px 10px; font-size: 12px;" %>
    </div>
  </nav>

  <div class="main-app-content">
    <% if @company_hq %>
      <div class="project-section">
        <span class="project-divider">Company HQ</span>
        <ul class="card-holder">
          <li class="card">
            <a href="<%= project_path(@company_hq) %>" class="card">
              <div class="project-card">
                <h1><%= @company_hq.name %></h1>
                <p><%= @company_hq.description %></p>
              </div>
            </a>
          </li>
        </ul>
      </div>
    <% end %>

    <% if @teams.any? %>
      <div class="project-section">
        <span class="project-divider">Teams</span>
        <ul class="card-holder">
          <% @teams.each do |team| %>
            <li class="card">
              <a href="<%= project_path(team) %>" class="card">
                <div class="project-card">
                  <h1><%= team.name %></h1>
                  <p><%= team.description %></p>
                </div>
              </a>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if @other_projects.any? %>
      <div class="project-section">
        <span class="project-divider">Projects</span>
        <ul class="card-holder">
          <% @other_projects.each do |project| %>
            <li class="card">
              <a href="<%= project_path(project) %>" class="card">
                <div class="project-card">
                  <h1><%= project.name %></h1>
                  <p><%= project.description %></p>
                </div>
              </a>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div style="text-align: center; margin-top: 20px;">
      <a href="<%= search_path %>" class="btn btn-primary" style="display: inline-block; margin-right: 10px;">Search</a>
      <a href="<%= everything_index_path %>" class="btn btn-primary" style="display: inline-block; margin-right: 10px;">Everything</a>
      <a href="<%= tags_path %>" class="btn btn-primary" style="display: inline-block; margin-right: 10px;">Tags</a>
      <a href="#" class="btn btn-primary" style="display: inline-block;">New Project</a>
    </div>
  </div>
</div>
