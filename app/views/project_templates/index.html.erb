<div class="main-app">
  <nav class="app-nav">
    <div style="display: flex; align-items: center;">
      <a href="/home" class="logo">
        <img src="https://res.cloudinary.com/basejump/image/upload/v1580630789/basecamp-logo-mini.png" alt="Home" />
      </a>
      <a href="/home" class="logo" style="margin-left: 5px;">
        <span>Home</span>
      </a>
    </div>
    <div>
      <a href="<%= user_path(current_user) %>" style="font-size: 13px; color: #555; text-decoration: none;"><%= current_user.name %></a>
      <%= button_to "Logout", session_path, method: :delete, class: "btn btn-normal", style: "padding: 5px 10px; font-size: 12px;" %>
    </div>
  </nav>

  <div class="main-app-content">
    <h1>Project Templates</h1>

    <% if @templates.any? %>
      <div class="card-holder">
        <% @templates.each do |template| %>
          <li class="card">
            <div class="project-card">
              <h2><%= template.name %></h2>
              <p><%= template.description %></p>
              <p style="font-size: 11px; color: #999;">
                <%= template.todo_lists.count %> todo lists · 
                <%= template.messages.count %> messages
              </p>
              <%= button_to "Use Template", use_template_path(template), 
                  method: :post, 
                  class: "btn btn-submit", 
                  style: "margin-top: 8px; font-size: 12px;" %>
            </div>
          </li>
        <% end %>
      </div>
    <% else %>
      <div style="text-align: center; padding: 40px; color: #999;">
        <p>No templates yet. Create a template from any project!</p>
      </div>
    <% end %>
  </div>
</div>
