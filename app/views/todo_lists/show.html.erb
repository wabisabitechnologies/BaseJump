<div class="min-h-screen bg-gray-100">
  <nav class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16">
        <div class="flex items-center">
          <%= link_to "← Back to #{@todo_list.project.name}", project_path(@todo_list.project), class: "text-sm text-blue-600 hover:text-blue-800 mr-4" %>
          <h1 class="text-xl font-bold text-gray-900"><%= @todo_list.title %></h1>
        </div>
        <div class="flex items-center">
          <span class="text-sm text-gray-700 mr-4"><%= current_user.name %></span>
          <%= button_to "Log out", session_path, method: :delete, class: "text-sm text-gray-500 hover:text-gray-700" %>
        </div>
      </div>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto py-6 px-4">
    <%# Loose Todos Section %>
    <% if @loose_todos.any? %>
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-gray-700 mb-3">Unsorted Todos</h2>
        <div id="loose-todos" class="space-y-2">
          <% @loose_todos.each do |todo| %>
            <%= render partial: "todos/todo", locals: { todo: todo } %>
          <% end %>
        </div>
      </section>
    <% end %>

    <%# Todos in this list %>
    <section>
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-semibold text-gray-700">Todos</h2>
        <span class="text-sm text-gray-500">
          <%= @todos.select(&:done).count %>/<%= @todos.count %> completed
        </span>
      </div>
      <div id="todos" class="space-y-2">
        <%= render partial: "todos/todo", collection: @todos, as: :todo %>
      </div>
    </section>

    <%# New Todo Form %>
    <div class="mt-6">
      <%= form_with model: [@todo_list, @todo_list.todos.new], local: true, class: "flex gap-2" do |f| %>
        <%= f.hidden_field :todo_list_id, value: @todo_list.id %>
        <%= f.text_field :title, placeholder: "Add a new todo...", class: "flex-1 rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2" %>
        <%= f.submit "Add", class: "inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700" %>
      <% end %>
    </div>
  </main>
</div>
