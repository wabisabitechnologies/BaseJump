<div class="main-app">
  <nav class="app-nav">
    <div class="flex justify-between" style="align-items: center;">
      <div class="flex" style="align-items: center;">
        <%= link_to project_path(@todo_list.project), class: "logo" do %>
          <img src="https://res.cloudinary.com/basejump/image/upload/v1580630150/basecamp-logo.svg" alt="BaseJump" style="height: 37px;">
        <% end %>
        <span style="margin-left: 10px; font-size: 13px; color: #007BB6; text-decoration: underline; font-weight: 700;">
          <%= link_to "← #{@todo_list.project.name}", project_path(@todo_list.project) %>
        </span>
      </div>
      <div class="flex" style="align-items: center;">
        <span style="font-size: 13px; margin-right: 10px;"><%= current_user.name %></span>
        <%= button_to "Log out", session_path, method: :delete, class: "btn btn-normal", style: "padding: 5px 10px; font-size: 12px;" %>
      </div>
    </div>
  </nav>

  <div class="tool-page">
    <header>
      <span>Todo List</span>
    </header>

    <div class="main-tool">
      <h1><%= @todo_list.title %></h1>
      <% if @todo_list.description.present? %>
        <h2><%= @todo_list.description %></h2>
      <% end %>

      <%# Loose Todos Section %>
      <% if @loose_todos.any? %>
        <div class="todolists">
          <h1>Unsorted Todos</h1>
          <div id="loose-todos">
            <% @loose_todos.each do |todo| %>
              <%= render partial: "todos/todo", locals: { todo: todo } %>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# Todos in this list %>
      <div class="todolists">
        <h1>Todos <span>(<%= @todos.select(&:done).count %>/<%= @todos.count %> completed)</span></h1>
        <div id="todos">
          <%= render partial: "todos/todo", collection: @todos, as: :todo %>
        </div>
      </div>

      <%# New Todo Form %>
      <div class="tool-form">
        <%= form_with model: [@todo_list, @todo_list.todos.new], local: true do |f| %>
          <div class="input-fields">
            <%= f.hidden_field :todo_list_id, value: @todo_list.id %>
            <%= f.text_field :title, placeholder: "Add a new todo..." %>
          </div>
          <div class="submit-buttons">
            <%= f.submit "Add", class: "btn btn-submit" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
