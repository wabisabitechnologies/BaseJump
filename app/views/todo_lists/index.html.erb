<div class="main-app">
  <nav class="app-nav">
    <div style="display: flex; align-items: center;">
      <a href="/home" class="logo">
        <img src="https://res.cloudinary.com/basejump/image/upload/v1580630789/basecamp-logo-mini.png" alt="Home" />
      </a>
      <a href="<%= project_path(@project) %>" class="logo" style="margin-left: 5px;">
        <span>Home</span>
      </a>
    </div>
    <div>
      <span style="font-size: 13px; color: #555;"><%= current_user.name %></span>
      <%= button_to "Logout", session_path, method: :delete, class: "btn btn-normal", style: "padding: 5px 10px; font-size: 12px;" %>
    </div>
  </nav>

  <div class="tool-page">
    <header>
      <span><%= link_to "← #{@project.name}", project_path(@project) %></span>
    </header>

    <div class="main-tool">
      <h1>Todo Lists</h1>

      <div class="tool-form todolist">
        <%= form_with model: [@project, @project.todo_lists.new], local: true do |f| %>
          <div class="input-fields">
            <%= f.text_field :title, placeholder: "New todo list..." %>
            <%= f.text_area :description, placeholder: "Description (optional)" %>
          </div>
          <div class="submit-buttons">
            <%= f.submit "Create List", class: "btn btn-submit" %>
          </div>
        <% end %>
      </div>

      <div class="todolists">
        <% @todo_lists.each do |list| %>
          <div class="todolist-item">
            <h1><%= link_to list.title, [list.project, list] %> <span>(<%= pluralize(list.todos.count, "todo") %>)</span></h1>
            <% if list.description.present? %>
              <p style="font-size: 13px; color: #666;"><%= list.description %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
