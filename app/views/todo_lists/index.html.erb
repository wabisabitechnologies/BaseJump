<div class="min-h-screen bg-gray-100">
  <nav class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16">
        <div class="flex items-center">
          <%= link_to "← Back to #{@project.name}", project_path(@project), class: "text-sm text-blue-600 hover:text-blue-800 mr-4" %>
          <h1 class="text-xl font-bold text-gray-900">Todo Lists</h1>
        </div>
        <div class="flex items-center">
          <span class="text-sm text-gray-700 mr-4"><%= current_user.name %></span>
          <%= button_to "Log out", session_path, method: :delete, class: "text-sm text-gray-500 hover:text-gray-700" %>
        </div>
      </div>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto py-6 px-4">
    <div class="mt-6">
      <%= form_with model: [@project, @project.todo_lists.new], local: true, class: "flex gap-2" do |f| %>
        <%= f.text_field :name, placeholder: "New todo list...", class: "flex-1 rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2" %>
        <%= f.text_area :description, placeholder: "Description (optional)", class: "flex-1 rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2" %>
        <%= f.submit "Create List", class: "inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700" %>
      <% end %>
    </div>

    <div class="space-y-3 mt-6">
      <% @todo_lists.each do |list| %>
        <div class="bg-white rounded-lg shadow p-4">
          <%= link_to [list.project, list], class: "block" do %>
            <h3 class="text-lg font-semibold text-blue-600 hover:text-blue-800"><%= list.name %></h3>
            <% if list.description.present? %>
              <p class="text-sm text-gray-500 mt-1"><%= list.description %></p>
            <% end %>
            <p class="text-xs text-gray-400 mt-2"><%= pluralize(list.todos.count, "todo") %></p>
          <% end %>
        </div>
      <% end %>
    </div>
  </main>
</div>
