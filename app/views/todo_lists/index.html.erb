<div class="main-app">
  <nav class="app-nav">
    <div class="flex justify-between" style="align-items: center;">
      <div class="flex" style="align-items: center;">
        <%= link_to project_path(@project), class: "logo" do %>
          <img src="https://res.cloudinary.com/basejump/image/upload/v1580630150/basecamp-logo.svg" alt="BaseJump" style="height: 37px;">
        <% end %>
        <span style="margin-left: 10px; font-size: 13px; color: #007BB6; text-decoration: underline; font-weight: 700;">
          <%= link_to "← #{@project.name}", project_path(@project) %>
        </span>
      </div>
      <div class="flex" style="align-items: center;">
        <span style="font-size: 13px; margin-right: 10px;"><%= current_user.name %></span>
        <%= button_to "Log out", session_path, method: :delete, class: "btn btn-normal", style: "padding: 5px 10px; font-size: 12px;" %>
      </div>
    </div>
  </nav>

  <div class="tool-page">
    <header>
      <span>Todo Lists</span>
    </header>

    <div class="main-tool">
      <h1>Todo Lists</h1>

      <%# New Todo List Form %>
      <div class="tool-form todolist">
        <%= form_with model: [@project, @project.todo_lists.new], local: true do |f| %>
          <div class="input-fields">
            <%= f.text_field :title, placeholder: "New todo list..." %>
            <%= f.text_area :description, placeholder: "Description (optional)" %>
          </div>
          <div class="submit-buttons">
            <%= f.submit "Create List", class: "btn btn-submit" %>
          </div>
        <% end %>
      </div>

      <%# Todo Lists %>
      <div class="todolists">
        <% @todo_lists.each do |list| %>
          <div class="todolist-item">
            <h1><%= link_to list.title, [list.project, list] %> <span>(<%= pluralize(list.todos.count, "todo") %>)</span></h1>
            <% if list.description.present? %>
              <p style="font-size: 13px; color: #666;"><%= list.description %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
