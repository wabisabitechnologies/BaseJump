<div class="main-app">
  <nav class="app-nav">
    <div style="display: flex; align-items: center;">
      <a href="/home" class="logo">
        <img src="https://res.cloudinary.com/basejump/image/upload/v1580630789/basecamp-logo-mini.png" alt="Home" />
      </a>
      <a href="/home" class="logo" style="margin-left: 5px;">
        <span>Home</span>
      </a>
    </div>
    <div>
      <a href="<%= user_path(current_user) %>" style="font-size: 13px; color: #555; text-decoration: none;"><%= current_user.name %></a>
      <%= button_to "Logout", session_path, method: :delete, class: "btn btn-normal", style: "padding: 5px 10px; font-size: 12px;" %>
    </div>
  </nav>

  <div class="main-app-content">
    <h1>Tags</h1>

    <div class="tool-form" style="max-width: 400px; margin: 20px auto;">
      <%= form_with model: Tag.new, data: { turbo_stream: true } do |f| %>
        <div class="input-fields" style="display: flex; gap: 8px;">
          <%= f.text_field :name, placeholder: "New tag name...", style: "flex: 1;" %>
          <%= f.color_field :color, value: "#007BB6", style: "width: 50px; padding: 4px;" %>
          <%= f.submit "Add", class: "btn btn-submit" %>
        </div>
      <% end %>
    </div>

    <div id="tags" style="display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 20px;">
      <% @tags.each do |tag| %>
        <div id="<%= dom_id(tag) %>" style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; background: <%= tag.color || '#007BB6' %>; color: white; border-radius: 16px; font-size: 13px;">
          <span><%= tag.name %></span>
          <%= button_to "×", tag_path(tag), method: :delete,
              data: { turbo_confirm: "Delete tag?" },
              style: "background: none; border: none; color: white; cursor: pointer; font-size: 14px; padding: 0; line-height: 1;" %>
        </div>
      <% end %>
    </div>

    <% if @tags.empty? %>
      <div style="text-align: center; padding: 40px; color: #999;">
        <p>No tags yet. Create one above!</p>
      </div>
    <% end %>
  </div>
</div>
